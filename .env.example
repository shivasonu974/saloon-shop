# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# ADMIN CREDENTIALS
# ============================================
# Default admin email and password for authentication
ADMIN_EMAIL=sonu@streetsaloon.com
ADMIN_PASSWORD=admin123

# JWT Secret for admin token signing
ADMIN_JWT_SECRET=admin-secret-key

# ============================================
# NOTIFICATION CHANNELS (Optional)
# ============================================

# --- WhatsApp Integration ---
# To enable WhatsApp notifications, configure one of:
# 1. Twilio: https://www.twilio.com/en-us/messaging/whatsapp
# 2. WhatsApp Cloud API: https://developers.facebook.com/docs/whatsapp/cloud-api
#
# Example for Twilio:
# WHATSAPP_API_URL=https://api.twilio.com/2010-04-01/Accounts/{AccountSID}/Messages.json
# WHATSAPP_API_TOKEN=Basic {Auth_Token}

WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# --- Email Integration ---
# To enable Email notifications, configure one of:
# 1. SendGrid: https://sendgrid.com/
# 2. AWS SES: https://aws.amazon.com/ses/

EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_TOKEN=

# ============================================
# FIREBASE CONFIGURATION (For Future Use)
# ============================================
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ============================================
# AI INTEGRATION (Optional)
# ============================================
GEMINI_API_KEY=
APP_URL=http://localhost:3000
